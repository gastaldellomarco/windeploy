# ============================================================
# WinDeploy — .gitignore Monorepo
# Stack: Laravel 11 + React 18/Vite + Python 3.11 Agent
# ============================================================

# ============================================================
# LARAVEL / PHP (backend/)
# ============================================================
backend/vendor/
backend/.env
backend/.env.backup
backend/.env.production
backend/storage/logs/
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/views/
backend/bootstrap/cache/
backend/public/hot
backend/public/storage
backend/.phpunit.result.cache
backend/.phpunit.cache/
backend/node_modules/

# ============================================================
# REACT / VITE (frontend/)
# ============================================================
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env.local
frontend/.env.production.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.vite/
frontend/coverage/

# ============================================================
# PYTHON AGENT (agent/)
# ============================================================
agent/venv/
agent/.venv/
agent/__pycache__/
agent/src/__pycache__/
agent/**/__pycache__/
agent/*.pyc
agent/**/*.pyc
agent/dist/
agent/build/
agent/*.exe
agent/*.spec
agent/.pytest_cache/
agent/htmlcov/
agent/.coverage

# ============================================================
# SISTEMA OPERATIVO
# ============================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ============================================================
# EDITOR / IDE
# ============================================================
# JetBrains (PhpStorm, PyCharm, WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.emacs.desktop

# ============================================================
# DEBUG E FILE TEMPORANEI
# ============================================================
tmp_*.php
tmp_*.js
tmp_*.py
*.log
*.bak
*.tmp
*.orig
*.rej
*.patch

# File debug WinDeploy (vedi security/backend issue)
debug_*.php
test_*.php
*_debug.php
*_test_manual.php

# ============================================================
# CERTIFICATI E SECRETS
# ============================================================
*.pem
*.key
*.crt
*.p12
*.pfx
.env*
!.env.example
!backend/.env.example
!frontend/.env.example
!agent/.env.example

# ============================================================
# DOCKER (se introdotto in futuro)
# ============================================================
docker-compose.override.yml
.docker/

# ============================================================
# AI WORKSPACE (non deployato)
# ============================================================
# NOTA: ai/ è INCLUSO nel repo ma escluso dal deploy.
# Non aggiungere ai/ qui. Vedi ai/README.md per le
# istruzioni di esclusione dagli script di deploy.

# ============================================================
# COVERAGE E TEST OUTPUT
# ============================================================
coverage/
*.lcov
clover.xml
junit.xml

# ============================================================
# PACKAGE MANAGERS
# ============================================================
# npm/yarn lock files — mantenere nel repo
# NON escludere package-lock.json o yarn.lock
.npm
.yarn/cache
.yarn/unplugged
.pnp.*

# Composer lock — mantenere nel repo
# NON escludere composer.lock
